#!/usr/bin/env sh

echo "Running pre-commit pipeline..."

run_step() {
  STEP_NAME=$1
  COMMAND=$2

  echo "[ ] $STEP_NAME"

  if eval "$COMMAND"; then
    echo "[✔] $STEP_NAME"
  else
    echo "[X] $STEP_NAME"
    exit 1
  fi
}

# 1. Build
run_step "Build" "npm run build"

# 2. Format
run_step "Format" "npm run format"

# 3. ESLint
run_step "ESLint" "npm run lint"

# 4. Tests
run_step "Tests" "npm test"

# 5. Coverage
run_step "Coverage" "npm run coverage"

echo "All checks passed. Ready to commit."
